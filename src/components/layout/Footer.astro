---
import { WA_LINK, WA_DISPLAY } from '../../utils/whatsapp';

const navLinks = [
  { href: '/', label: 'Beranda' },
  { href: '/tentang-kami', label: 'Tentang Kami' },
  { href: '/layanan', label: 'Layanan' },
  { href: '/harga', label: 'Harga' },
  { href: '/blog', label: 'Blog' },
  { href: '/kontak', label: 'Kontak' },
];

const serviceLinks = [
  { href: '/layanan', label: 'Konsultasi Online Gratis' },
  { href: '/layanan', label: '2x Pertemuan Langsung Gratis' },
  { href: '/layanan', label: 'Program Pendampingan' },
];
---

<footer class="bg-medical-trust-dark text-clean-cloud-dark">
  <!-- Main Footer -->
  <div class="container-main py-16">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-10">

      <!-- Brand Column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2.5 mb-4">
          <div class="w-9 h-9 rounded-xl bg-medical-trust flex items-center justify-center">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
              <path d="M12 4C8.5 4 5.5 6.5 5 10C4.5 10 2 10.5 2 13.5C2 16 4 17 5.5 17H8C8 18.1 8.9 19 10 19H14C15.1 19 16 18.1 16 17H18.5C20 17 22 16 22 13.5C22 10.5 19.5 10 19 10C18.5 6.5 15.5 4 12 4Z" fill="#10B981" opacity="0.9"/>
              <path d="M12 7C10 7 8.3 8.3 8 10H16C15.7 8.3 14 7 12 7Z" fill="white"/>
            </svg>
          </div>
          <span class="font-nunito font-bold text-white text-base">Berhenti Merokok</span>
        </a>
        <p class="font-opensans text-sm text-clean-cloud-dark/70 leading-relaxed mb-6 max-w-xs">
          Misi kami adalah membantu setiap perokok mendapatkan kesempatan untuk hidup lebih sehat melalui konsultasi medis yang terjangkau dan empatik.
        </p>
        <div class="flex gap-3">
          <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
             class="w-9 h-9 rounded-lg bg-recovery-green/20 hover:bg-recovery-green/40 flex items-center justify-center transition-colors"
             aria-label="WhatsApp">
            <svg class="w-5 h-5 text-recovery-green-light" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.549 4.103 1.508 5.831L.057 23.48a.496.496 0 00.6.6l5.748-1.508A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.813 9.813 0 01-5.001-1.374l-.359-.213-3.717.975.992-3.617-.234-.371A9.816 9.816 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <h3 class="font-nunito font-bold text-white text-sm uppercase tracking-wider mb-5">Navigasi</h3>
        <ul class="space-y-3" role="list">
          {navLinks.map(link => (
            <li>
              <a href={link.href}
                 class="font-opensans text-sm text-clean-cloud-dark/70 hover:text-recovery-green-light transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Services -->
      <div>
        <h3 class="font-nunito font-bold text-white text-sm uppercase tracking-wider mb-5">Layanan</h3>
        <ul class="space-y-3" role="list">
          {serviceLinks.map(link => (
            <li>
              <a href={link.href}
                 class="font-opensans text-sm text-clean-cloud-dark/70 hover:text-recovery-green-light transition-colors">
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <h3 class="font-nunito font-bold text-white text-sm uppercase tracking-wider mb-5">Kontak</h3>
        <ul class="space-y-4" role="list">
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-recovery-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
            </svg>
            <a href={`tel:${WA_DISPLAY.replace(/\s/g, '')}`}
               class="font-opensans text-sm text-clean-cloud-dark/70 hover:text-recovery-green-light transition-colors">
              {WA_DISPLAY}
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-recovery-green mt-0.5 shrink-0" fill="currentColor" viewBox="0 0 24 24">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
            </svg>
            <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
               class="font-opensans text-sm text-clean-cloud-dark/70 hover:text-recovery-green-light transition-colors">
              WhatsApp (klik untuk chat)
            </a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-4 h-4 text-recovery-green mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <span class="font-opensans text-sm text-clean-cloud-dark/70">
              Senin – Sabtu<br/>08.00 – 17.00 WIB
            </span>
          </li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Footer Bottom -->
  <div class="border-t border-white/10">
    <div class="container-main py-5 flex flex-col sm:flex-row items-center justify-between gap-3">
      <p class="font-opensans text-xs text-clean-cloud-dark/50 text-center sm:text-left">
        © 2026 Layanan Konsultasi Berhenti Merokok. Hak cipta dilindungi.
      </p>
      <div class="flex gap-4">
        <a href="/privasi" class="font-opensans text-xs text-clean-cloud-dark/50 hover:text-recovery-green-light transition-colors">Privasi</a>
        <a href="/syarat" class="font-opensans text-xs text-clean-cloud-dark/50 hover:text-recovery-green-light transition-colors">Syarat</a>
      </div>
    </div>
  </div>
</footer>
