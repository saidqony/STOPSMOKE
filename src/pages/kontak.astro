---
import BaseLayout from '../components/layout/BaseLayout.astro';
import { WA_LINK, WA_DISPLAY } from '../utils/whatsapp';
---

<BaseLayout
  title="Kontak"
  description="Hubungi tim dokter ahli berhenti merokok kami via WhatsApp 0857-2773-969 atau formulir kontak. Jam operasional Senin-Sabtu 08.00-17.00 WIB."
>
  <!-- Hero -->
  <section class="section-pad-sm bg-clean-cloud border-b border-clean-cloud-dark">
    <div class="container-main text-center">
      <span class="section-label reveal">Hubungi Kami</span>
      <h1 class="font-lora font-semibold text-medical-trust leading-tight mb-4 reveal"
          style="font-size: clamp(28px, 4vw, 44px);" data-delay="100">
        Kami Siap Membantu Anda
      </h1>
      <p class="font-opensans text-text-muted text-lead max-w-xl mx-auto reveal" data-delay="200">
        Hubungi tim dokter kami langsung via WhatsApp atau formulir di bawah ini.
      </p>
    </div>
  </section>

  <!-- Main Content -->
  <section class="section-pad bg-white">
    <div class="container-main">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-20">

        <!-- Left: Contact Info & WhatsApp -->
        <div>
          <!-- WhatsApp Direct -->
          <div class="bg-recovery-green/5 border-2 border-recovery-green/20 rounded-3xl p-8 mb-8 reveal">
            <div class="flex items-center gap-3 mb-4">
              <div class="w-12 h-12 rounded-2xl bg-recovery-green flex items-center justify-center">
                <svg class="w-6 h-6 text-white" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.549 4.103 1.508 5.831L.057 23.48a.496.496 0 00.6.6l5.748-1.508A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.813 9.813 0 01-5.001-1.374l-.359-.213-3.717.975.992-3.617-.234-.371A9.816 9.816 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
                </svg>
              </div>
              <div>
                <h2 class="font-nunito font-bold text-medical-trust text-xl">Chat WhatsApp Langsung</h2>
                <p class="font-opensans text-text-muted text-sm">Cara tercepat untuk terhubung</p>
              </div>
            </div>
            <p class="font-nunito font-bold text-medical-trust text-3xl mb-4">{WA_DISPLAY}</p>
            <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
               class="btn-primary w-full justify-center"
               onclick="if(typeof gtag!=='undefined'){gtag('event','whatsapp_click',{event_category:'contact_page',event_label:'contact_whatsapp'});}">
              <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/><path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.549 4.103 1.508 5.831L.057 23.48a.496.496 0 00.6.6l5.748-1.508A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.813 9.813 0 01-5.001-1.374l-.359-.213-3.717.975.992-3.617-.234-.371A9.816 9.816 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/></svg>
              Buka WhatsApp Sekarang
            </a>
          </div>

          <!-- Contact Info Cards -->
          <div class="space-y-4 reveal" data-delay="150">
            {[
              {
                icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>`,
                title: 'Jam Operasional',
                lines: ['Senin – Sabtu: 08.00 – 17.00 WIB', 'Minggu & Hari Libur: Tutup'],
              },
              {
                icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>`,
                title: 'Lokasi Klinik',
                lines: ['Tersedia setelah konfirmasi jadwal', 'via WhatsApp'],
              },
              {
                icon: `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>`,
                title: 'Email',
                lines: ['info@berhenti-merokok.id', 'Respon dalam 24 jam kerja'],
              },
            ].map(item => (
              <div class="flex items-start gap-4 bg-clean-cloud rounded-2xl p-5">
                <div class="w-10 h-10 rounded-xl bg-medical-trust/10 text-medical-trust flex items-center justify-center shrink-0"
                     set:html={item.icon}>
                </div>
                <div>
                  <p class="font-nunito font-semibold text-medical-trust text-sm mb-1">{item.title}</p>
                  {item.lines.map(line => (
                    <p class="font-opensans text-text-muted text-sm">{line}</p>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>

        <!-- Right: Contact Form -->
        <div class="reveal" data-delay="200">
          <div class="card-base p-8">
            <h2 class="font-nunito font-bold text-medical-trust text-2xl mb-2">Kirim Pesan</h2>
            <p class="font-opensans text-text-muted text-sm mb-6">
              Isi formulir di bawah ini dan tim kami akan merespon dalam 24 jam.
            </p>

            <form
              id="contact-form"
              action="https://formspree.io/f/YOUR_FORM_ID"
              method="POST"
              class="space-y-5"
              novalidate
            >
              <!-- Honeypot -->
              <input type="text" name="_gotcha" class="hidden" aria-hidden="true" tabindex="-1" autocomplete="off" />
              <input type="hidden" name="_subject" value="Konsultasi Berhenti Merokok — Pesan Baru" />

              <!-- Name -->
              <div>
                <label for="contact-name" class="block font-opensans font-semibold text-medical-trust text-sm mb-2">
                  Nama Lengkap <span class="text-red-500">*</span>
                </label>
                <input
                  type="text"
                  id="contact-name"
                  name="name"
                  required
                  placeholder="Masukkan nama Anda"
                  class="w-full border border-clean-cloud-dark rounded-xl px-4 py-3 font-opensans text-sm
                         text-text-body bg-clean-cloud focus:outline-none focus:border-medical-trust focus:ring-2
                         focus:ring-medical-trust/10 transition-all placeholder:text-text-light"
                />
              </div>

              <!-- Email -->
              <div>
                <label for="contact-email" class="block font-opensans font-semibold text-medical-trust text-sm mb-2">
                  Email <span class="text-red-500">*</span>
                </label>
                <input
                  type="email"
                  id="contact-email"
                  name="email"
                  required
                  placeholder="nama@email.com"
                  class="w-full border border-clean-cloud-dark rounded-xl px-4 py-3 font-opensans text-sm
                         text-text-body bg-clean-cloud focus:outline-none focus:border-medical-trust focus:ring-2
                         focus:ring-medical-trust/10 transition-all placeholder:text-text-light"
                />
              </div>

              <!-- Phone -->
              <div>
                <label for="contact-phone" class="block font-opensans font-semibold text-medical-trust text-sm mb-2">
                  Nomor WhatsApp
                </label>
                <input
                  type="tel"
                  id="contact-phone"
                  name="phone"
                  placeholder="08xxxxxxxxxx"
                  class="w-full border border-clean-cloud-dark rounded-xl px-4 py-3 font-opensans text-sm
                         text-text-body bg-clean-cloud focus:outline-none focus:border-medical-trust focus:ring-2
                         focus:ring-medical-trust/10 transition-all placeholder:text-text-light"
                />
              </div>

              <!-- Message -->
              <div>
                <label for="contact-message" class="block font-opensans font-semibold text-medical-trust text-sm mb-2">
                  Pesan <span class="text-red-500">*</span>
                </label>
                <textarea
                  id="contact-message"
                  name="message"
                  required
                  rows="4"
                  placeholder="Ceritakan kondisi Anda atau pertanyaan yang ingin disampaikan..."
                  class="w-full border border-clean-cloud-dark rounded-xl px-4 py-3 font-opensans text-sm
                         text-text-body bg-clean-cloud focus:outline-none focus:border-medical-trust focus:ring-2
                         focus:ring-medical-trust/10 transition-all placeholder:text-text-light resize-none"
                ></textarea>
              </div>

              <!-- Submit -->
              <button
                type="submit"
                id="submit-btn"
                class="btn-primary w-full justify-center"
              >
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/>
                </svg>
                Kirim Pesan
              </button>

              <!-- Status messages -->
              <div id="form-success" class="hidden bg-recovery-green/10 border border-recovery-green/30 rounded-xl p-4 text-center">
                <p class="font-opensans text-recovery-green-dark text-sm font-semibold">
                  ✓ Pesan berhasil dikirim! Kami akan merespon dalam 24 jam.
                </p>
              </div>
              <div id="form-error" class="hidden bg-red-50 border border-red-200 rounded-xl p-4 text-center">
                <p class="font-opensans text-red-600 text-sm">
                  ✗ Terjadi kesalahan. Silakan coba lagi atau hubungi via WhatsApp.
                </p>
              </div>

              <p class="font-opensans text-xs text-text-light text-center">
                Dengan mengirim pesan, Anda menyetujui{' '}
                <a href="/privasi" class="underline hover:text-medical-trust transition-colors">kebijakan privasi</a>
                {' '}kami. Data Anda aman dan tidak disebarkan.
              </p>
            </form>
          </div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const submitBtn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successMsg = document.getElementById('form-success') as HTMLElement;
  const errorMsg = document.getElementById('form-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Mengirim...';

    try {
      const data = new FormData(form);
      const response = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (response.ok) {
        form.reset();
        successMsg?.classList.remove('hidden');
        if (typeof gtag !== 'undefined') {
          gtag('event', 'contact_form_submit', { event_category: 'contact', event_label: 'form_success' });
        }
      } else {
        errorMsg?.classList.remove('hidden');
      }
    } catch {
      errorMsg?.classList.remove('hidden');
    } finally {
      submitBtn.disabled = false;
      submitBtn.innerHTML = `<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 19l9 2-9-18-9 18 9-2zm0 0v-8"/></svg> Kirim Pesan`;
    }
  });
</script>
