---
import { WA_LINK } from '../../../utils/whatsapp';
---

<section class="relative overflow-hidden bg-clean-cloud section-pad">
  <!-- Radial gradient decoration -->
  <div class="absolute inset-0 pointer-events-none" aria-hidden="true">
    <div class="absolute top-0 left-0 w-[600px] h-[600px] rounded-full"
         style="background: radial-gradient(circle, rgba(16,185,129,0.07) 0%, transparent 70%); transform: translate(-30%, -30%);">
    </div>
    <div class="absolute bottom-0 right-0 w-[400px] h-[400px] rounded-full"
         style="background: radial-gradient(circle, rgba(30,58,138,0.05) 0%, transparent 70%); transform: translate(30%, 30%);">
    </div>
  </div>

  <div class="container-main relative">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-12 lg:gap-16 items-center">

      <!-- Text Content -->
      <div class="reveal">
        <!-- Label -->
        <div class="flex items-center gap-2 mb-6">
          <span class="section-label">Konsultasi Gratis</span>
          <span class="font-opensans text-sm text-text-muted">dengan Dokter Ahli</span>
        </div>

        <!-- H1 -->
        <h1 class="font-lora font-semibold text-medical-trust mb-6 leading-tight"
            style="font-size: clamp(36px, 5vw, 52px); letter-spacing: -0.02em;">
          Berhenti Merokok<br/>
          adalah <span class="text-recovery-green italic">Perjalanan</span>,<br/>
          Bukan Destinasi.
        </h1>

        <!-- Sub text -->
        <p class="font-opensans text-text-muted text-lead mb-8 max-w-lg leading-relaxed">
          Konsultasi gratis dengan dokter ahli. Dua kali pertemuan langsung gratis.
          Kami menemani setiap langkah perjalanan Anda menuju hidup bebas rokok.
        </p>

        <!-- CTAs -->
        <div class="flex flex-wrap gap-4 mb-8">
          <a href={WA_LINK} target="_blank" rel="noopener noreferrer"
             class="btn-primary"
             onclick="if(typeof gtag!=='undefined'){gtag('event','whatsapp_click',{event_category:'hero',event_label:'hero_primary_cta'});}">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
              <path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.549 4.103 1.508 5.831L.057 23.48a.496.496 0 00.6.6l5.748-1.508A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.813 9.813 0 01-5.001-1.374l-.359-.213-3.717.975.992-3.617-.234-.371A9.816 9.816 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
            </svg>
            Tanya Dokter Gratis Sekarang
          </a>
          <a href="/layanan" class="btn-secondary">
            Lihat Program Lengkap
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
            </svg>
          </a>
        </div>

        <!-- Trust badges -->
        <div class="flex flex-wrap gap-x-6 gap-y-2">
          {[
            '500+ Pasien Berhasil',
            '4.9 ★ Rating Google',
            'Dokter Spesialis Paru',
          ].map(badge => (
            <div class="flex items-center gap-2">
              <svg class="w-4 h-4 text-recovery-green shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/>
              </svg>
              <span class="font-opensans text-sm text-text-muted">{badge}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Illustration -->
      <div class="reveal flex justify-center lg:justify-end" data-delay="200">
        <div class="relative w-full max-w-md">
          <!-- Main illustration card -->
          <div class="bg-white rounded-3xl shadow-card-hover p-8 border border-clean-cloud-dark animate-float">
            <svg viewBox="0 0 400 350" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full" aria-label="Ilustrasi konsultasi dokter pasien">
              <!-- Background circle -->
              <circle cx="200" cy="175" r="140" fill="#F0FDF4" opacity="0.6"/>

              <!-- Doctor figure -->
              <g>
                <!-- Body -->
                <rect x="130" y="170" width="70" height="100" rx="35" fill="#1E3A8A"/>
                <!-- White coat -->
                <rect x="133" y="175" width="64" height="90" rx="32" fill="white" opacity="0.9"/>
                <!-- Stethoscope -->
                <path d="M155 195 Q165 210 175 195" stroke="#10B981" stroke-width="3" fill="none" stroke-linecap="round"/>
                <circle cx="175" cy="192" r="5" fill="#10B981"/>
                <!-- Head -->
                <circle cx="165" cy="155" r="28" fill="#FBBF24"/>
                <!-- Hair -->
                <path d="M137 150 Q165 125 193 150" fill="#1E3A8A"/>
                <!-- Eyes -->
                <circle cx="157" cy="152" r="3" fill="#1E3A8A"/>
                <circle cx="173" cy="152" r="3" fill="#1E3A8A"/>
                <!-- Smile -->
                <path d="M158 162 Q165 168 172 162" stroke="#1E3A8A" stroke-width="2" fill="none" stroke-linecap="round"/>
              </g>

              <!-- Patient figure -->
              <g>
                <!-- Body -->
                <rect x="215" y="180" width="65" height="90" rx="32" fill="#E2E8F0"/>
                <!-- Head -->
                <circle cx="247" cy="162" r="26" fill="#F59E0B"/>
                <!-- Hair -->
                <path d="M221 155 Q247 132 273 155" fill="#374151"/>
                <!-- Eyes -->
                <circle cx="239" cy="159" r="3" fill="#374151"/>
                <circle cx="255" cy="159" r="3" fill="#374151"/>
                <!-- Smile -->
                <path d="M240 169 Q247 175 254 169" stroke="#374151" stroke-width="2" fill="none" stroke-linecap="round"/>
              </g>

              <!-- Chat bubble -->
              <g>
                <rect x="260" y="100" width="120" height="65" rx="16" fill="#10B981"/>
                <polygon points="270,165 260,180 285,165" fill="#10B981"/>
                <text x="280" y="125" fill="white" font-size="11" font-family="sans-serif" font-weight="600">Konsultasi</text>
                <text x="280" y="142" fill="white" font-size="11" font-family="sans-serif" font-weight="600">100% Gratis</text>
                <text x="280" y="156" fill="rgba(255,255,255,0.8)" font-size="9" font-family="sans-serif">✓ Tanpa biaya</text>
              </g>

              <!-- Heart decoration -->
              <g transform="translate(50, 80)">
                <path d="M20 8C20 8 12 0 4 8C-4 16 12 28 20 36C28 28 44 16 36 8C28 0 20 8 20 8Z" fill="#EF4444" opacity="0.8"/>
              </g>

              <!-- Stars -->
              <text x="60" y="230" fill="#F59E0B" font-size="20">★</text>
              <text x="330" y="240" fill="#10B981" font-size="16">✦</text>
              <text x="80" y="290" fill="#3B82F6" font-size="12">✦</text>
            </svg>
          </div>

          <!-- Floating stat cards -->
          <div class="absolute -left-6 top-1/4 bg-white rounded-2xl shadow-card-hover p-3 border border-clean-cloud-dark animate-float" style="animation-delay: 0.5s;">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-recovery-green/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-recovery-green" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0"/>
                </svg>
              </div>
              <div>
                <p class="font-nunito font-bold text-medical-trust text-sm">500+</p>
                <p class="font-opensans text-xs text-text-muted">Pasien Berhasil</p>
              </div>
            </div>
          </div>

          <div class="absolute -right-4 bottom-1/4 bg-white rounded-2xl shadow-card-hover p-3 border border-clean-cloud-dark animate-float" style="animation-delay: 1s;">
            <div class="flex items-center gap-2">
              <div class="w-8 h-8 rounded-lg bg-medical-trust/10 flex items-center justify-center">
                <svg class="w-4 h-4 text-medical-trust" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"/>
                </svg>
              </div>
              <div>
                <p class="font-nunito font-bold text-medical-trust text-sm">4.9 ★</p>
                <p class="font-opensans text-xs text-text-muted">Rating Pasien</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
