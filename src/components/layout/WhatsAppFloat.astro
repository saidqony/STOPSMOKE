---
import { WA_LINK } from '../../utils/whatsapp';
---

<a
  href={WA_LINK}
  target="_blank"
  rel="noopener noreferrer"
  id="whatsapp-float"
  class="fixed bottom-6 right-6 z-50 group"
  aria-label="Chat WhatsApp"
  onclick="if(typeof gtag!=='undefined'){gtag('event','whatsapp_click',{event_category:'floating_button',event_label:'whatsapp_float'});}"
>
  <!-- Pulse rings -->
  <span class="absolute inset-0 rounded-full bg-recovery-green animate-pulse-ring opacity-70"></span>
  <span class="absolute inset-0 rounded-full bg-recovery-green animate-pulse-ring opacity-40" style="animation-delay:0.5s;"></span>

  <!-- Button -->
  <div class="relative w-16 h-16 rounded-full bg-recovery-green shadow-cta-lg flex items-center justify-center
              group-hover:bg-recovery-green-dark group-hover:scale-110 transition-all duration-300">
    <svg class="w-8 h-8 text-white" fill="currentColor" viewBox="0 0 24 24" aria-hidden="true">
      <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
      <path d="M12 0C5.373 0 0 5.373 0 12c0 2.116.549 4.103 1.508 5.831L.057 23.48a.496.496 0 00.6.6l5.748-1.508A11.945 11.945 0 0012 24c6.627 0 12-5.373 12-12S18.627 0 12 0zm0 21.818a9.813 9.813 0 01-5.001-1.374l-.359-.213-3.717.975.992-3.617-.234-.371A9.816 9.816 0 012.182 12C2.182 6.57 6.57 2.182 12 2.182c5.43 0 9.818 4.388 9.818 9.818 0 5.43-4.388 9.818-9.818 9.818z"/>
    </svg>
  </div>

  <!-- Tooltip -->
  <span class="absolute right-20 top-1/2 -translate-y-1/2 bg-medical-trust-dark text-white
               font-opensans text-xs font-medium px-3 py-1.5 rounded-lg whitespace-nowrap
               opacity-0 group-hover:opacity-100 transition-opacity duration-200 pointer-events-none shadow-lg">
    Tanya Dokter Gratis
  </span>
</a>
